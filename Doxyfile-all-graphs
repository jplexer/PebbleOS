# Same as Doxyfile, but with all dependency graphs enabled (see `waf docs-all`).
@INCLUDE               = Doxyfile

JAVADOC_AUTOBRIEF      = NO
FILE_PATTERNS          = *.c *.h
INLINE_SOURCES         = YES
GENERATE_LATEX         = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             =
HIDE_UNDOC_RELATIONS   = YES
HAVE_DOT               = YES
