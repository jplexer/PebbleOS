# Select the active board's manufacturing sources.
if bld.env.CONFIG_QEMU:
    mfg_board = 'qemu'
elif bld.env.CONFIG_BOARD_ASTERIX:
    mfg_board = 'asterix'
elif bld.env.CONFIG_BOARD_OBELIX:
    mfg_board = 'obelix'
elif bld.env.CONFIG_BOARD_GETAFIX:
    mfg_board = 'getafix'
else:
    bld.fatal('No MFG configuration for board {}'.format(bld.env.BOARD))

sources = bld.path.ant_glob('*.c')
sources += bld.path.ant_glob('{}/*.c'.format(mfg_board))
# Factory mode is only built into the recovery (PRF) firmware.
if bld.env.VARIANT == 'prf':
    sources += bld.path.ant_glob('mfg_mode/*.c')

bld.objects(
    name='mfg',
    source=sources,
    use=[
        'fw_includes',
        'pbl_includes',
    ],
)

