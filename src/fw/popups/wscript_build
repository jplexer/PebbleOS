if bld.env.VARIANT == 'prf':
    # Recovery only needs the BT pairing UI.
    source = ['bluetooth_pairing_ui.c']
else:
    excl = [] if bld.env.CONFIG_HRM else ['ble_hrm/**']
    source = bld.path.ant_glob('**/*.c', excl=excl)

bld.objects(
    name='popups',
    source=source,
    use=['fw_includes'],
)

