bld.recurse('demo')
bld.recurse('system')

if bld.env.CONFIG_SHELL_SDK:
    bld.recurse('sdk')
else:
    # The watch faces are only part of the normal (non-SDK) shell.
    bld.recurse('watch')

# Collect translatable strings from all app sources (independent of which
# apps the active configuration actually builds). Recovery-only apps live
# in their own firmware variant and are excluded.
bld.gettext(source=bld.path.ant_glob('**/*.c', excl=['prf/**']), target='apps.pot')

