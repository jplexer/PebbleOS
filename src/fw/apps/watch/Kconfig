menu "Watch faces"

choice
    prompt "TicToc watch face"
    default APPS_WATCH_TICTOC_ROUND if PLATFORM_GABBRO
    default APPS_WATCH_TICTOC_BW if SCREEN_COLOR_DEPTH_BITS_1
    default APPS_WATCH_TICTOC_DEFAULT
    help
      Which built-in TicToc watch face variant to build.

config APPS_WATCH_TICTOC_DEFAULT
    bool "Default (color, rectangular)"

config APPS_WATCH_TICTOC_BW
    bool "Black and white (1-bit)"

config APPS_WATCH_TICTOC_ROUND
    bool "Round"

endchoice

endmenu
