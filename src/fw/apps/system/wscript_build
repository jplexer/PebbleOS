if bld.env.CONFIG_SHELL_SDK:
    # The SDK shell only ships a subset of the system apps.
    source = (bld.path.ant_glob('timeline/*.c')
              + bld.path.ant_glob('launcher/default/**/*.c')
              + ['app_fetch_ui.c', 'watchfaces.c'])
else:
    source = bld.path.ant_glob('**/*.c')

bld.objects(
    name='apps_system',
    source=source,
    use=['fw_includes'],
)
bld.env.FW_APPS.append('apps_system')

