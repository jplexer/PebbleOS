# Board/feature-specific manufacturing test apps.
excl = []
if not bld.env.CONFIG_BOARD_ASTERIX:
    excl += ['mfg_speaker_asterix.c', 'mfg_mic_asterix.c']
if not bld.env.CONFIG_BOARD_OBELIX:
    excl += ['mfg_speaker_obelix.c', 'mfg_mic_obelix.c']
if not (bld.env.CONFIG_BOARD_OBELIX and bld.env.CONFIG_MFG):
    excl += ['mfg_hrm_ctr_leakage_obelix.c']
if not bld.env.CONFIG_BOARD_GETAFIX:
    excl += ['mfg_mic_getafix.c']
if not bld.env.CONFIG_MAG:
    excl += ['mfg_mag.c']
if not bld.env.CONFIG_TOUCH:
    excl += ['mfg_touch.c']

use = ['fw_includes', 'pblibc_includes']
# mfg_hrm_ctr_leakage_obelix.c includes the gh3x2x demo headers.
if bld.env.CONFIG_BOARD_OBELIX and bld.env.CONFIG_MFG:
    use.append('gh3x2x')

bld.objects(
    name='apps_prf',
    source=bld.path.ant_glob('**/*.c', excl=excl),
    use=use,
)
bld.env.FW_APPS.append('apps_prf')

