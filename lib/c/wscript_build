if bld.variant != 'test':
    # __assert_func override: the assert() hook of the newlib-family
    # <assert.h> shared by all supported libcs.
    bld.objects(
        name='libc_assert',
        source=['assert.c'],
        use=['fw_includes'],
    )

    # _sbrk override: the firmware owns all heaps via --wrap=malloc ->
    # pbl_malloc, so the libc must never grow its own heap.
    bld.objects(
        name='libc_syscalls',
        source=['syscalls.c'],
        use=['fw_includes'],
    )

    # newlib-nano's printf lacks C99 length modifiers; provide a shim.
    if bld.env.CONFIG_LIBC_NEWLIB_NANO:
        bld.recurse('newlib')

